# Auto-generated by scripts/abc-export
# Replays exported local sources from this directory.

set _export_script [file normalize [info script]]
set _export_dir [file dirname $_export_script]

read_sv [file join $_export_dir {submod.sv}]
read_sv [file join $_export_dir {top.sv}]

set _xdc [read_xdc -unmanaged -ref {mod} [file join $_export_dir {submod.xdc}]]
